{
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./.env.dev)",
      "Read(./.env.development)",
      "Read(./.env.prod)",
      "Read(./.env.production)",
      "Read(./.env.test)",
      "Read(./.env.staging)",
      "Read(./.env.ci)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Read(**/.env.dev)",
      "Read(**/.env.development)",
      "Read(**/.env.prod)",
      "Read(**/.env.production)",
      "Read(**/.env.test)",
      "Read(**/.env.staging)",
      "Read(**/.env.ci)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/credentials*.json)",
      "Read(**/secrets/**)"
    ],
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true
}
