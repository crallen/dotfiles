{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "architect",
  "autoupdate": true,
  "permission": {
    "read": {
      "~/**": "deny",
      "~/dev/**": "allow",
      "~/code/**": "allow",
      "~/Projects/**": "allow"
    },
    "glob": {
      "~/**": "deny",
      "~/dev/**": "allow",
      "~/code/**": "allow",
      "~/Projects/**": "allow"
    },
    "grep": {
      "~/**": "deny",
      "~/dev/**": "allow",
      "~/code/**": "allow",
      "~/Projects/**": "allow"
    },
    "list": {
      "~/**": "deny",
      "~/dev/**": "allow",
      "~/code/**": "allow",
      "~/Projects/**": "allow"
    },
    "edit": {
      "*": "deny",
      "./**": "allow"
    },
    "external_directory": {
      "*": "deny",
      "~/dev/**": "allow",
      "~/code/**": "allow",
      "~/Projects/**": "allow"
    },
    "bash": "allow",
    "task": "allow",
    "skill": "allow",
    "question": "allow",
    "todowrite": "allow"
  }
}